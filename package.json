{
  "name": "skywings",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "sync:blob": "node scripts/sync-vercel-blob.mjs",
    "sync:blob:dry-run": "node scripts/sync-vercel-blob.mjs --dry-run",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "vercel-build": "pnpm payload migrate && pnpm run build"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@payloadcms/db-vercel-postgres": "3.85.2",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/storage-vercel-blob": "^3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/xr": "^6.6.30",
    "@tanstack/react-query": "^5.101.2",
    "camera-controls": "^3.1.2",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "motion": "^12.42.2",
    "next": "16.2.6",
    "payload": "3.85.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.80.0",
    "sharp": "0.34.2",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "4.5.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-tailwindcss": "^4.0.6",
    "gltfjsx": "^6.5.3",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "r3f-perf": "^7.2.3",
    "shadcn": "^4.13.0",
    "tsx": "4.22.4",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}
